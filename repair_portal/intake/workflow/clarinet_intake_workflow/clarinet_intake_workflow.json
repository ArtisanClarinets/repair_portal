{
  "doctype": "Workflow",
  "workflow_name": "Clarinet Intake Workflow",
  "document_type": "Clarinet Intake",
  "is_active": 1,
  "name": "Clarinet Intake Workflow",
  "module": "Intake",
  "workflow_state_field": "workflow_state",
  "states": [
    {
      "state": "Received",
      "doc_status": 0
    },
    {
      "state": "In Progress",
      "doc_status": 0
    },
    {
      "state": "Inspection",
      "doc_status": 0
    },
    {
      "state": "Awaiting Customer Approval",
      "doc_status": 0
    },
    {
      "state": "Repair",
      "doc_status": 0
    },
    {
      "state": "Awaiting Payment",
      "doc_status": 0
    },
    {
      "state": "Repair Complete",
      "doc_status": 1
    },
    {
      "state": "Returned to Customer",
      "doc_status": 1
    },
    {
      "state": "Rejected",
      "doc_status": 2
    }
  ],
  "transitions": [
    {
      "state": "Received",
      "action": "Begin Intake",
      "next_state": "In Progress",
      "allowed": [
        "Technician"
      ]
    },
    {
      "state": "In Progress",
      "action": "Send to Inspection",
      "next_state": "Inspection",
      "allowed": [
        "Technician"
      ]
    },
    {
      "state": "Inspection",
      "action": "Request Approval",
      "next_state": "Awaiting Customer Approval",
      "allowed": [
        "Technician"
      ]
    },
    {
      "state": "Awaiting Customer Approval",
      "action": "Approve",
      "next_state": "Repair",
      "allowed": [
        "Repair Manager",
        "System Manager"
      ]
    },
    {
      "state": "Awaiting Customer Approval",
      "action": "Reject",
      "next_state": "Rejected",
      "allowed": [
        "Repair Manager",
        "System Manager"
      ]
    },
    {
      "state": "Repair",
      "action": "Complete Repair",
      "next_state": "Awaiting Payment",
      "allowed": [
        "Technician"
      ]
    },
    {
      "state": "Awaiting Payment",
      "action": "Mark as Complete",
      "next_state": "Repair Complete",
      "allowed": [
        "Repair Manager"
      ]
    },
    {
      "state": "Repair Complete",
      "action": "Return to Customer",
      "next_state": "Returned to Customer",
      "allowed": [
        "Repair Manager"
      ]
    },
    {
      "state": "Returned to Customer",
      "action": "Close",
      "next_state": "Closed",
      "allowed": [
        "System Manager"
      ]
    }
  ]
}