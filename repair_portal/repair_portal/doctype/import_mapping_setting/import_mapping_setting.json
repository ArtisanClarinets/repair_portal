{
  "doctype": "DocType",
  "name": "Import Mapping Setting",
  "module": "Repair Portal",
  "custom": 1,
  "engine": "InnoDB",
  "title_field": "mapping_name",
  "search_fields": "mapping_name",
  "sort_field": "modified",
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ],
  "fields": [
    {
      "fieldname": "mapping_name",
      "label": "Mapping Name",
      "fieldtype": "Data",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1,
      "index": 1,
      "description": "Unique name for this import mapping."
    },
    {
      "fieldname": "target_doctype",
      "label": "Target DocType",
      "fieldtype": "Link",
      "options": "DocType",
      "reqd": 1,
      "in_list_view": 1,
      "description": "The DocType this mapping applies to."
    },
    {
      "fieldname": "enable_versioning",
      "label": "Enable Versioning",
      "fieldtype": "Check",
      "default": 1,
      "description": "Keep a history of imports to rollback if needed."
    },
    {
      "fieldname": "child_mapping",
      "label": "Field Mappings",
      "fieldtype": "Table",
      "options": "Import Mapping Setting Field",
      "reqd": 1
    }
  ],
  "in_standard_filter": 1,
  "ignore_print_on_null": 0,
  "track_changes": 1,
  "workflow_state_field": "",
  "links": []
}
