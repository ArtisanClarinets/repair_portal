{
  "doctype": "DocType",
  "name": "Instrument Inspection",
  "module": "Inspection",
  "custom": 0,
  "istable": 0,
  "editable_grid": 1,
  "fields": [
    {"fieldname": "inspection_date", "label": "Inspection Date", "fieldtype": "Date", "default": "Today", "reqd": 1},
    {"fieldname": "inspection_type", "label": "Inspection Type", "fieldtype": "Select", "options": "New Inventory\nRepair\nMaintenance\nQA\nOther", "reqd": 1},
    {"fieldname": "serial_no", "label": "Instrument Serial Number", "fieldtype": "Link", "options": "Serial No", "reqd": 1, "in_filter": 1, "in_global_search": 1, "unique": 1},
    {"fieldname": "clarinet_intake", "label": "Clarinet Intake", "fieldtype": "Link", "options": "Clarinet Intake"},
    {"fieldname": "inspected_by", "label": "Inspected By", "fieldtype": "Link", "options": "User", "reqd": 1},
    {"fieldname": "customer", "label": "Customer", "fieldtype": "Link", "options": "Customer", "depends_on": "eval:doc.inspection_type !== 'New Inventory'"},
    {"fieldname": "preliminary_estimate", "label": "Preliminary Estimate", "fieldtype": "Currency", "depends_on": "eval:doc.inspection_type !== 'New Inventory'"},
    {"fieldname": "manufacturer", "label": "Manufacturer", "fieldtype": "Data", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "model", "label": "Model", "fieldtype": "Data", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "key", "label": "Key", "fieldtype": "Select", "options": "B♭\nA\nE♭\nC\nD", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "wood_type", "label": "Wood Type", "fieldtype": "Select", "options": "Grenadilla\nMopane\nCocobolo\nSynthetic\nOther", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "unboxing_rh", "label": "Initial Relative Humidity (%)", "fieldtype": "Float", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "unboxing_temperature", "label": "Initial Temperature (°C)", "fieldtype": "Float", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "unboxing_time", "label": "Date and Time of Unboxing", "fieldtype": "Datetime", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "hygrometer_photo", "label": "Hygrometer Reading Photo", "fieldtype": "Attach Image", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "rested_unopened", "label": "Instrument Rested Min. 4 Hours Before Handling", "fieldtype": "Check", "default": "0", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "acclimatization_controlled_env", "label": "Controlled Environment Confirmed", "fieldtype": "Check", "default": "0", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "acclimatization_playing_schedule", "label": "Daily Playing Schedule Explained", "fieldtype": "Check", "default": "0", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "acclimatization_swabbing", "label": "Swabbing Protocol Explained", "fieldtype": "Check", "default": "0", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "overall_condition", "label": "Overall Condition", "fieldtype": "Select", "options": "Excellent\nGood\nFair\nPoor", "depends_on": "eval:doc.inspection_type !== 'New Inventory'"},
    {"fieldname": "visual_inspection", "label": "Visual Inspection Findings", "fieldtype": "Table", "options": "Inspection Finding"},
    {"fieldname": "tenon_fit_assessment", "label": "Tenon Fit Assessment", "fieldtype": "Table", "options": "Tenon Fit Assessment"},
    {"fieldname": "bore_condition", "label": "Bore Visual Condition", "fieldtype": "Select", "options": "Clean\nDebris Present\nIrregularities Visible", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "bore_notes", "label": "Bore Inspection Notes", "fieldtype": "Small Text", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "tone_hole_inspection", "label": "Tone Hole Visual Inspection", "fieldtype": "Table", "options": "Tone Hole Inspection Record"},
    {"fieldname": "tone_hole_notes", "label": "Tone Hole Inspection Notes", "fieldtype": "Text"},
    {"fieldname": "inspection_findings", "label": "Inspection Findings", "fieldtype": "Table", "options": "Inspection Finding"},
    {"fieldname": "notes", "label": "General Notes", "fieldtype": "Text"},
    {"fieldname": "instrument_delivered", "label": "Instrument Delivered to Customer", "fieldtype": "Check", "default": "0", "depends_on": "eval:doc.inspection_type === 'New Inventory'"},
    {"fieldname": "qc_certificate", "label": "QC Certificate", "fieldtype": "Attach"},
    {"fieldname": "digital_signature", "label": "Technician Signature", "fieldtype": "Signature"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "Technician", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "Service Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "delete": 1}
  ],
  "workflow_state_field": "status"
}
